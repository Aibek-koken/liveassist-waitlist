# ─────────────────────────────────────────────────────────────
# LiveAssist AI · waitlist — переменные окружения
# Скопируй в .env.local и заполни. .env.local НЕ коммитится.
# ─────────────────────────────────────────────────────────────

# URL проекта Supabase в формате https://<project-ref>.supabase.co
# (НЕ /rest/v1 эндпоинт)
SUPABASE_URL=

# Service role key. Используется ТОЛЬКО на сервере (route handler).
# НИКОГДА не префикси его через NEXT_PUBLIC_ и не импортируй в клиент.
SUPABASE_SERVICE_ROLE_KEY=

# Поведение без Supabase:
#   - development: форма работает в явном demo-режиме (заявка НЕ сохраняется,
#     сервер отвечает { ok: true, demo: true } и пишет предупреждение в лог).
#   - production: форма честно возвращает ошибку 503 "not_configured" —
#     фальшивой «успешной» отправки в production нет.
